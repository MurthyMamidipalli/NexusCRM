rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the current user the owner of the document?
    function isOwner(data) {
      return request.auth != null && data != null && request.auth.uid == data.ownerId;
    }

    // Helper: Is the profile explicitly marked as public?
    function isPublicProfile(ownerId) {
      let path = /databases/$(database)/documents/profiles/$(ownerId);
      return exists(path) && get(path).data.isPublic == true;
    }

    // Profiles: Anyone can view a specific profile, but only the owner can list or write.
    match /profiles/{uid} {
      allow get: if true;
      allow list: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Public Collections: Owner has full access, visitors have READ access if the profile is public.
    match /skills/{id} {
      allow read: if isOwner(resource.data) || isPublicProfile(resource.data.ownerId);
      allow write: if isOwner(request.resource.data) || isOwner(resource.data);
    }
    match /experience/{id} {
      allow read: if isOwner(resource.data) || isPublicProfile(resource.data.ownerId);
      allow write: if isOwner(request.resource.data) || isOwner(resource.data);
    }
    match /education/{id} {
      allow read: if isOwner(resource.data) || isPublicProfile(resource.data.ownerId);
      allow write: if isOwner(request.resource.data) || isOwner(resource.data);
    }
    match /projects/{id} {
      allow read: if isOwner(resource.data) || isPublicProfile(resource.data.ownerId);
      allow write: if isOwner(request.resource.data) || isOwner(resource.data);
    }
    match /achievements/{id} {
      allow read: if isOwner(resource.data) || isPublicProfile(resource.data.ownerId);
      allow write: if isOwner(request.resource.data) || isOwner(resource.data);
    }
    match /certifications/{id} {
      allow read: if isOwner(resource.data) || isPublicProfile(resource.data.ownerId);
      allow write: if isOwner(request.resource.data) || isOwner(resource.data);
    }
    match /links/{id} {
      allow read: if isOwner(resource.data) || isPublicProfile(resource.data.ownerId);
      allow write: if isOwner(request.resource.data) || isOwner(resource.data);
    }
    match /resumes/{id} {
      allow read: if isOwner(resource.data) || isPublicProfile(resource.data.ownerId);
      allow write: if isOwner(request.resource.data) || isOwner(resource.data);
    }
    match /testimonials/{id} {
      allow read: if isOwner(resource.data) || isPublicProfile(resource.data.ownerId);
      allow write: if isOwner(request.resource.data) || isOwner(resource.data);
    }

    // Private Vault Collections: Strictly owner-only access.
    match /contacts/{id} {
      allow read, write: if isOwner(resource.data) || isOwner(request.resource.data);
    }
    match /documents/{id} {
      allow read, write: if isOwner(resource.data) || isOwner(request.resource.data);
    }
    match /tasks/{id} {
      allow read, write: if isOwner(resource.data) || isOwner(request.resource.data);
    }
    match /meetings/{id} {
      allow read, write: if isOwner(resource.data) || isOwner(request.resource.data);
    }
    match /leads/{id} {
      allow read, write: if isOwner(resource.data) || isOwner(request.resource.data);
    }

    // Drafts: Specialized ownership based on document ID prefix
    match /drafts/{id} {
      allow read, write: if request.auth != null && id.startsWith('lead-draft-' + request.auth.uid);
    }
  }
}