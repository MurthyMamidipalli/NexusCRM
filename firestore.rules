rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Profiles: Anyone can read a profile (public check handled in-app), only owner can write.
    match /profiles/{uid} {
      allow get: if true;
      allow list, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // Generic rule for all user-owned records (Leads, Skills, Certifications, etc.)
    match /{collection}/{id} {
      // READ: Allow if owner OR if item is marked public
      allow read: if (isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid)) 
                  || (resource != null && resource.data.isPublic == true);
      
      // CREATE: Must be authenticated and setting themselves as owner
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      
      // UPDATE/DELETE: Must be the owner
      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }
    
    // Internal Drafts handling
    match /drafts/{id} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
    }
  }
}