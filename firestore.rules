rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Basic Authentication
    function auth() {
      return request.auth != null;
    }

    // Helper: Ownership check
    function isOwner(data) {
      return auth() && data != null && data.ownerId == request.auth.uid;
    }

    // Profiles: Anyone can view a specific profile, only owner can write.
    match /profiles/{uid} {
      allow get: if true;
      allow list, write: if auth() && request.auth.uid == uid;
    }

    // Generic rule for all top-level user-owned collections
    // This covers skills, experience, education, projects, achievements, certifications, resumes, documents, links, testimonials, contacts, leads, tasks, meetings.
    match /{collection}/{id} {
      // READ: Allow if user owns the record OR if it is explicitly marked as Public
      allow read: if auth() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow read: if resource != null && resource.data.isPublic == true;
      
      // WRITE: Allow if the user is authenticated and is setting themselves as the owner
      allow create: if auth() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data);
    }
    
    // Drafts (Internal helper collection)
    match /drafts/{id} {
      allow read, write: if auth() && id.startsWith('lead-draft-' + request.auth.uid);
    }
  }
}