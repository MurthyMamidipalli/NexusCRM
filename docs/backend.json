
{
  "entities": {
    "Profile": {
      "title": "Personal Profile",
      "description": "User's core identity, bio, and contact information.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "fullName": { "type": "string" },
        "tagline": { "type": "string" },
        "bio": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "secondaryEmail": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "secondaryPhone": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other", "Prefer not to say"] },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "ownerId": { "type": "string" },
        "isPublic": { "type": "boolean", "description": "CRITICAL: Determines if this profile is publicly accessible to unauthenticated visitors." },
        "currentJob": {
          "type": "object",
          "properties": {
            "company": { "type": "string" },
            "title": { "type": "string" },
            "startDate": { "type": "string" },
            "endDate": { "type": "string" },
            "employmentType": { "type": "string" },
            "workSetting": { "type": "string" }
          }
        }
      }
    },
    "Skill": {
      "title": "Skill",
      "description": "Professional expertise and competencies.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Technical", "Soft Skills", "Tools", "Languages"] },
        "level": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "ownerId": { "type": "string" }
      }
    },
    "Experience": {
      "title": "Experience",
      "description": "Professional work history.",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Education": {
      "title": "Education",
      "description": "Academic background.",
      "type": "object",
      "properties": {
        "degree": { "type": "string" },
        "institution": { "type": "string" },
        "fieldOfStudy": { "type": "string" },
        "idNumber": { "type": "string", "description": "Student ID or enrollment number." },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "cgpa": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "Showcase of work and products.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Contact": {
      "title": "Contact",
      "description": "Professional network and connections.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "industry": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Document": {
      "title": "Secure Document",
      "description": "Encrypted-at-rest personal and professional documents.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "vaultGroup": { "type": "string", "enum": ["My self", "Family"], "description": "Folder-level grouping." },
        "category": { "type": "string", "enum": ["Aadhaar Card", "PAN Card", "Driving Licence", "Passport", "Voter ID", "Property Documents", "Insurance Documents", "Tax Documents", "Medical Records", "Other Documents"] },
        "description": { "type": "string" },
        "fileUrl": { "type": "string" },
        "filePath": { "type": "string" },
        "fileType": { "type": "string" },
        "fileSize": { "type": "number" },
        "status": { "type": "string", "enum": ["active"] },
        "ownerId": { "type": "string" }
      }
    },
    "Resume": {
      "title": "Resume",
      "description": "CV files and portfolio links.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["file", "link"] },
        "url": { "type": "string" },
        "fileUrl": { "type": "string" },
        "ownerId": { "type": "string" },
        "isPublic": { "type": "boolean", "description": "Mandatory: Allow public viewing and download of this resume." }
      }
    },
    "Achievement": {
      "title": "Achievement",
      "description": "Awards and milestones.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Certification": {
      "title": "Certification",
      "description": "Professional certifications and grade sheets.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "ownerId": { "type": "string" },
        "isPublic": { "type": "boolean", "description": "Mandatory: Allow public viewing of this certification." }
      }
    },
    "Lead": {
      "title": "Lead",
      "description": "Sales lead information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "company": { "type": "string" },
        "status": { "type": "string" },
        "value": { "type": "number" },
        "ownerId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/profiles/{uid}": { "schema": "#/entities/Profile", "description": "User profile data. READ access should be public if isPublic is true." },
    "/skills/{skillId}": { "schema": "#/entities/Skill", "description": "User skills. READ access is public for any visitor viewing a public profile hub." },
    "/experience/{expId}": { "schema": "#/entities/Experience", "description": "Work history. READ access is public for any visitor viewing a public profile hub." },
    "/education/{eduId}": { "schema": "#/entities/Education", "description": "Education history. READ access is public for any visitor viewing a public profile hub." },
    "/projects/{projectId}": { "schema": "#/entities/Project", "description": "Portfolio projects. READ access is public for any visitor viewing a public profile hub." },
    "/contacts/{contactId}": { "schema": "#/entities/Contact", "description": "Network contacts. PRIVATE: Only owner can access." },
    "/documents/{docId}": { "schema": "#/entities/Document", "description": "PRIVATE: Secure personal document vault. Only owner can access." },
    "/resumes/{resId}": { "schema": "#/entities/Resume", "description": "Resume records. PRIVATE: Only owner can access unless explicitly marked public." },
    "/leads/{leadId}": { "schema": "#/entities/Lead", "description": "Sales leads. PRIVATE: Only owner can access." },
    "/achievements/{achId}": { "schema": "#/entities/Achievement", "description": "Awards and honors. READ access is public for any visitor viewing a public profile hub." },
    "/certifications/{certId}": { "schema": "#/entities/Certification", "description": "Credentials. PRIVATE: Only owner can access unless explicitly marked public." }
  }
}
