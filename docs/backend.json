
{
  "entities": {
    "Profile": {
      "title": "Personal Profile",
      "description": "User's core identity, bio, and contact information.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "tagline": { "type": "string" },
        "bio": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "links": { "type": "array", "items": { "type": "object", "properties": { "label": { "type": "string" }, "url": { "type": "string" } } } }
      }
    },
    "Skill": {
      "title": "Skill",
      "description": "Professional expertise and proficiency levels.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Technical", "Soft Skills", "Tools", "Languages"] },
        "level": { "type": "number", "description": "1 to 100" }
      }
    },
    "Experience": {
      "title": "Experience",
      "description": "Professional work history.",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "isCurrent": { "type": "boolean" },
        "description": { "type": "string" }
      }
    },
    "Education": {
      "title": "Education",
      "description": "Academic background.",
      "type": "object",
      "properties": {
        "degree": { "type": "string" },
        "institution": { "type": "string" },
        "fieldOfStudy": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "grade": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "Showcase of work and products.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "technologies": { "type": "array", "items": { "type": "string" } },
        "url": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["In Progress", "Completed", "Archived"] }
      }
    },
    "Achievement": {
      "title": "Achievement",
      "description": "Awards and notable accomplishments.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" }
      }
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Professional endorsements and reviews.",
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "role": { "type": "string" },
        "company": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date" }
      }
    },
    "Contact": {
      "title": "Contact",
      "description": "Professional network and connections.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "company": { "type": "string" },
        "relationship": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/profiles/{uid}": { "schema": "#/entities/Profile", "description": "User profile data." },
    "/skills/{skillId}": { "schema": "#/entities/Skill", "description": "User skills." },
    "/experience/{expId}": { "schema": "#/entities/Experience", "description": "Work history." },
    "/education/{eduId}": { "schema": "#/entities/Education", "description": "Education history." },
    "/projects/{projectId}": { "schema": "#/entities/Project", "description": "Portfolio projects." },
    "/achievements/{achId}": { "schema": "#/entities/Achievement", "description": "Awards and achievements." },
    "/testimonials/{testId}": { "schema": "#/entities/Testimonial", "description": "Professional testimonials." },
    "/contacts/{contactId}": { "schema": "#/entities/Contact", "description": "Network contacts." }
  }
}
