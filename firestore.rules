rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a profile is public
    function isProfilePublic(uid) {
      return get(/databases/$(database)/documents/profiles/$(uid)).data.isPublic == true;
    }

    // Profiles: Publicly readable if isPublic is true, otherwise only by owner
    match /profiles/{uid} {
      allow read: if resource.data.isPublic == true || request.auth.uid == uid;
      allow write: if request.auth.uid == uid;
    }

    // Skills, Experience, Education, Projects: Publicly readable if the owner's profile is public
    match /skills/{id} {
      allow read: if isProfilePublic(resource.data.ownerId) || request.auth.uid == resource.data.ownerId;
      allow write: if request.auth.uid == request.resource.data.ownerId || (resource != null && request.auth.uid == resource.data.ownerId);
    }
    match /experience/{id} {
      allow read: if isProfilePublic(resource.data.ownerId) || request.auth.uid == resource.data.ownerId;
      allow write: if request.auth.uid == request.resource.data.ownerId || (resource != null && request.auth.uid == resource.data.ownerId);
    }
    match /education/{id} {
      allow read: if isProfilePublic(resource.data.ownerId) || request.auth.uid == resource.data.ownerId;
      allow write: if request.auth.uid == request.resource.data.ownerId || (resource != null && request.auth.uid == resource.data.ownerId);
    }
    match /projects/{id} {
      allow read: if isProfilePublic(resource.data.ownerId) || request.auth.uid == resource.data.ownerId;
      allow write: if request.auth.uid == request.resource.data.ownerId || (resource != null && request.auth.uid == resource.data.ownerId);
    }
    match /achievements/{id} {
      allow read: if isProfilePublic(resource.data.ownerId) || request.auth.uid == resource.data.ownerId;
      allow write: if request.auth.uid == request.resource.data.ownerId || (resource != null && request.auth.uid == resource.data.ownerId);
    }
    match /testimonials/{id} {
      allow read: if isProfilePublic(resource.data.ownerId) || request.auth.uid == resource.data.ownerId;
      allow write: if request.auth.uid == request.resource.data.ownerId || (resource != null && request.auth.uid == resource.data.ownerId);
    }

    // Private Collections: Only the owner can access
    match /contacts/{id} {
      allow read, write: if request.auth.uid == resource.data.ownerId || request.auth.uid == request.resource.data.ownerId;
    }
    match /documents/{id} {
      allow read, write: if request.auth.uid == resource.data.ownerId || request.auth.uid == request.resource.data.ownerId;
    }
    match /resumes/{id} {
      allow read, write: if request.auth.uid == resource.data.ownerId || request.auth.uid == request.resource.data.ownerId;
    }
    match /leads/{id} {
      allow read, write: if request.auth.uid == resource.data.ownerId || request.auth.uid == request.resource.data.ownerId;
    }
    match /certifications/{id} {
      allow read, write: if request.auth.uid == resource.data.ownerId || request.auth.uid == request.resource.data.ownerId;
    }
    match /links/{id} {
      allow read, write: if request.auth.uid == resource.data.ownerId || request.auth.uid == request.resource.data.ownerId;
    }
    match /tasks/{id} {
      allow read, write: if request.auth.uid == resource.data.ownerId || request.auth.uid == request.resource.data.ownerId;
    }
    match /meetings/{id} {
      allow read, write: if request.auth.uid == resource.data.ownerId || request.auth.uid == request.resource.data.ownerId;
    }
    match /drafts/{id} {
      allow read, write: if request.auth.uid == resource.data.ownerId || request.auth.uid == request.resource.data.ownerId || id.startsWith('lead-draft-' + request.auth.uid);
    }
  }
}
