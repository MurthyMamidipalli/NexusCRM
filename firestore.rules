
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a profile is public safely
    function isProfilePublic(uid) {
      let profilePath = /databases/$(database)/documents/profiles/$(uid);
      return exists(profilePath) && get(profilePath).data.isPublic == true;
    }

    // Profiles: Allow visitors to 'get' by ID to check public status
    // List is restricted to the owner only
    match /profiles/{uid} {
      allow get: if true; 
      allow list: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Career Data: Publicly readable ONLY if the owner's profile is public
    match /skills/{id} {
      allow read: if isProfilePublic(resource.data.ownerId) || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow write: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }
    match /experience/{id} {
      allow read: if isProfilePublic(resource.data.ownerId) || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow write: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }
    match /education/{id} {
      allow read: if isProfilePublic(resource.data.ownerId) || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow write: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }
    match /projects/{id} {
      allow read: if isProfilePublic(resource.data.ownerId) || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow write: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }
    match /achievements/{id} {
      allow read: if isProfilePublic(resource.data.ownerId) || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow write: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }
    match /testimonials/{id} {
      allow read: if isProfilePublic(resource.data.ownerId) || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow write: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // Private Collections: Only the owner can access
    match /contacts/{id} {
      allow read, write: if request.auth != null && (resource == null || resource.data.ownerId == request.auth.uid) && (request.resource == null || request.resource.data.ownerId == request.auth.uid);
    }
    match /documents/{id} {
      allow read, write: if request.auth != null && (resource == null || resource.data.ownerId == request.auth.uid) && (request.resource == null || request.resource.data.ownerId == request.auth.uid);
    }
    match /resumes/{id} {
      allow read, write: if request.auth != null && (resource == null || resource.data.ownerId == request.auth.uid) && (request.resource == null || request.resource.data.ownerId == request.auth.uid);
    }
    match /leads/{id} {
      allow read, write: if request.auth != null && (resource == null || resource.data.ownerId == request.auth.uid) && (request.resource == null || request.resource.data.ownerId == request.auth.uid);
    }
    match /certifications/{id} {
      allow read, write: if request.auth != null && (resource == null || resource.data.ownerId == request.auth.uid) && (request.resource == null || request.resource.data.ownerId == request.auth.uid);
    }
    match /links/{id} {
      allow read, write: if request.auth != null && (resource == null || resource.data.ownerId == request.auth.uid) && (request.resource == null || request.resource.data.ownerId == request.auth.uid);
    }
    match /tasks/{id} {
      allow read, write: if request.auth != null && (resource == null || resource.data.ownerId == request.auth.uid) && (request.resource == null || request.resource.data.ownerId == request.auth.uid);
    }
    match /meetings/{id} {
      allow read, write: if request.auth != null && (resource == null || resource.data.ownerId == request.auth.uid) && (request.resource == null || request.resource.data.ownerId == request.auth.uid);
    }
    match /drafts/{id} {
      allow read, write: if request.auth != null && (id.startsWith('lead-draft-' + request.auth.uid));
    }
  }
}
