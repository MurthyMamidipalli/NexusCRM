
{
  "entities": {
    "Profile": {
      "title": "Personal Profile",
      "description": "User's core identity, bio, and contact information.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "tagline": { "type": "string" },
        "bio": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "secondaryEmail": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "secondaryPhone": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other", "Prefer not to say"] },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "ownerId": { "type": "string" },
        "publicProfile": { "type": "boolean", "description": "CRITICAL: Determines if this profile is publicly accessible to unauthenticated visitors." },
        "currentJob": {
          "type": "object",
          "properties": {
            "company": { "type": "string" },
            "title": { "type": "string" },
            "startDate": { "type": "string" },
            "endDate": { "type": "string" },
            "employmentType": { "type": "string" },
            "workSetting": { "type": "string" }
          }
        }
      }
    },
    "Skill": {
      "title": "Skill",
      "description": "Professional expertise and competencies.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Technical", "Soft Skills", "Tools", "Languages"] },
        "ownerId": { "type": "string" }
      }
    },
    "Experience": {
      "title": "Experience",
      "description": "Professional work history.",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Education": {
      "title": "Education",
      "description": "Academic background.",
      "type": "object",
      "properties": {
        "degree": { "type": "string" },
        "institution": { "type": "string" },
        "fieldOfStudy": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "cgpa": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "Showcase of work and products.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Contact": {
      "title": "Contact",
      "description": "Professional network and connections.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "industry": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Document": {
      "title": "Document",
      "description": "Stored files and assets.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Resume": {
      "title": "Resume",
      "description": "CV files and portfolio links.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["file", "link"] },
        "url": { "type": "string" },
        "fileUrl": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Achievement": {
      "title": "Achievement",
      "description": "Awards and milestones.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Certification": {
      "title": "Certification",
      "description": "Professional certifications and grade sheets.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Lead": {
      "title": "Lead",
      "description": "Sales lead information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "company": { "type": "string" },
        "status": { "type": "string" },
        "value": { "type": "number" },
        "ownerId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/profiles/{uid}": { "schema": "#/entities/Profile", "description": "User profile data. READ access should be public if publicProfile is true." },
    "/skills/{skillId}": { "schema": "#/entities/Skill", "description": "User skills." },
    "/experience/{expId}": { "schema": "#/entities/Experience", "description": "Work history." },
    "/education/{eduId}": { "schema": "#/entities/Education", "description": "Education history." },
    "/projects/{projectId}": { "schema": "#/entities/Project", "description": "Portfolio projects." },
    "/contacts/{contactId}": { "schema": "#/entities/Contact", "description": "Network contacts." },
    "/documents/{docId}": { "schema": "#/entities/Document", "description": "Vault documents." },
    "/resumes/{resId}": { "schema": "#/entities/Resume", "description": "Resume records." },
    "/leads/{leadId}": { "schema": "#/entities/Lead", "description": "Sales leads." },
    "/achievements/{achId}": { "schema": "#/entities/Achievement", "description": "Awards and honors." },
    "/certifications/{certId}": { "schema": "#/entities/Certification", "description": "Credentials." }
  }
}
