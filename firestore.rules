rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Basic Authentication
    function auth() {
      return request.auth != null;
    }

    // Helper: Ownership check
    function isOwner(data) {
      return auth() && data != null && data.ownerId == request.auth.uid;
    }

    // Profiles: Anyone can view a specific profile, only owner can list or write.
    match /profiles/{uid} {
      allow get: if true;
      allow list, write: if auth() && request.auth.uid == uid;
    }

    // Shared collections with item-level visibility
    // Logic: Owner has full access. Visitors can READ only if isPublic is true.
    match /{collection}/{id} {
      allow read: if isOwner(resource.data);
      allow read: if (collection in ['skills', 'experience', 'education', 'projects', 'achievements', 'certifications', 'resumes', 'documents', 'links', 'testimonials'])
                   && resource.data.isPublic == true;
      
      // Write access strictly for owners
      allow create: if auth() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data);
    }

    // Strictly private collections
    match /contacts/{id} { allow read, write: if isOwner(resource.data) || (auth() && request.resource.data.ownerId == request.auth.uid); }
    match /leads/{id} { allow read, write: if isOwner(resource.data) || (auth() && request.resource.data.ownerId == request.auth.uid); }
    match /tasks/{id} { allow read, write: if isOwner(resource.data) || (auth() && request.resource.data.ownerId == request.auth.uid); }
    match /meetings/{id} { allow read, write: if isOwner(resource.data) || (auth() && request.resource.data.ownerId == request.auth.uid); }
    
    // Drafts
    match /drafts/{id} {
      allow read, write: if auth() && id.startsWith('lead-draft-' + request.auth.uid);
    }
  }
}