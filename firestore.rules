
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Profiles: Anyone can get a profile, only owner can write.
    match /profiles/{uid} {
      allow get: if true;
      allow list, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // Secure Documents: Strictly private. Only owner can access.
    match /documents/{docId} {
      allow read, write: if isAuthenticated() && 
        (resource == null || resource.data.ownerId == request.auth.uid) &&
        (request.resource == null || request.resource.data.ownerId == request.auth.uid);
    }

    // Generic rule for all other user-owned records
    match /{collection}/{id} {
      // READ: Allow if owner OR if item is marked public
      allow read: if (isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid)) 
                  || (resource != null && resource.data.isPublic == true);
      
      // CREATE/WRITE: Must be owner. Direct ownership check for performance.
      allow create, update, delete: if isAuthenticated() && 
        (request.resource == null || request.resource.data.ownerId == request.auth.uid) &&
        (resource == null || resource.data.ownerId == request.auth.uid);
    }
    
    // Internal Drafts handling
    match /drafts/{id} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
    }
  }
}
