
{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential sales opportunity or prospect enriched with professional background.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "jobTitle": { "type": "string" },
        "education": { "type": "string" },
        "experience": { "type": "string" },
        "links": { "type": "string", "description": "Comma separated URLs (LinkedIn, Portfolio, etc.)" },
        "status": { "type": "string", "enum": ["New", "Contacted", "Qualified", "Proposal Sent", "Negotiation", "Won", "Lost"] },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "ownerId": { "type": "string" },
        "value": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A converted lead or existing client.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "industry": { "type": "string" },
        "revenue": { "type": "number" },
        "since": { "type": "string" }
      }
    },
    "Deal": {
      "title": "Deal",
      "description": "An active sales opportunity in the pipeline.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "company": { "type": "string" },
        "value": { "type": "number" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "ownerId": { "type": "string" },
        "closingDate": { "type": "string", "format": "date" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "An activity to be completed.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "leadId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "status": { "type": "string", "enum": ["Pending", "Completed"] },
        "assignedTo": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "#/entities/Lead",
      "description": "Collection of sales leads."
    },
    "/customers/{customerId}": {
      "schema": "#/entities/Customer",
      "description": "Collection of active customers."
    },
    "/deals/{dealId}": {
      "schema": "#/entities/Deal",
      "description": "Collection of sales deals."
    },
    "/tasks/{taskId}": {
      "schema": "#/entities/Task",
      "description": "User tasks and activities."
    }
  }
}
